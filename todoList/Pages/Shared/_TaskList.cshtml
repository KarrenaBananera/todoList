<div class="task-list-container">
    <div id="taskListContent" class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <!-- Task cards will be injected here via JS -->
    </div>

    <!-- Empty state -->
    <div id="emptyState" class="text-center py-5 d-none">
        <i class="bi bi-clipboard-x display-1 text-muted"></i>
        <h4 class="mt-3 text-muted">No tasks found</h4>
        <p class="text-muted">Try changing your filters or create a new task.</p>
    </div>

    <!-- Pagination -->
    <nav aria-label="Task pagination" class="mt-4">
        <ul class="pagination justify-content-center" id="paginationControls">
            <!-- Pagination items will be injected here via JS -->
        </ul>
    </nav>
</div>
