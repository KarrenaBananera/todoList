<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-light border-bottom shadow-sm mb-3">
        <div class="container">
            <a class="navbar-brand fs-4 fw-bold text-primary" asp-area="" asp-page="/Index">
                <i class="bi bi-check2-square"></i> TaskMaster
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-page="/Index">My Tasks</a>
                    </li>
                </ul>
                <div id="authContainer" class="d-flex align-items-center">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <span class="me-3 text-muted">Welcome, @User.Identity.Name!</span>
                        <form method="post" asp-page="/Logout" class="d-inline">
                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill" id="btnLogout">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a asp-page="/Login" class="btn btn-outline-primary btn-sm rounded-pill me-2">Login</a>
                        <a asp-page="/Register" class="btn btn-primary btn-sm rounded-pill">Register</a>
                    }
                </div>
            </div>
        </div>
    </nav>
</header>
