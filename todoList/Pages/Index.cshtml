@page
@model IndexModel
@{
    ViewData["Title"] = "My Tasks";
}

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="task-app-container">
        @Html.AntiForgeryToken()
        @await Html.PartialAsync("_TaskControls")
        @await Html.PartialAsync("_TaskList")
        @await Html.PartialAsync("_TaskFormModal")
        @await Html.PartialAsync("_DeleteConfirmModal")
        
        <!-- Toast for Notifications -->
        <div class="toast-container position-fixed bottom-0 end-0 p-3">
            <div id="appToast" class="toast align-items-center text-white border-0" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body" id="appToastMessage">
                        <!-- Message goes here -->
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="container mt-5 text-center">
        <div class="p-5 mb-4 bg-light rounded-3 shadow-sm border">
            <div class="container-fluid py-5">
                <h1 class="display-5 fw-bold text-primary mb-3">Welcome to TaskMaster!</h1>
                <p class="col-md-8 mx-auto fs-4 text-muted">
                    To start managing your tasks and being productive, you need to create an account or log in.
                </p>
                <div class="mt-4">
                    <a asp-page="/Login" class="btn btn-primary btn-lg rounded-pill px-4 me-3">Log in</a>
                    <a asp-page="/Register" class="btn btn-outline-primary btn-lg rounded-pill px-4">Register</a>
                </div>
            </div>
        </div>
    </div>
}
